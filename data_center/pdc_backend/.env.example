# ============================================================
# Bayt Alebaa — PDC Backend — متغيرات البيئة
# ============================================================
# 1. انسخ هذا الملف:  cp .env.example .env
# 2. ضع القيم الحقيقية
# 3. لا تُضف ملف .env إلى git أبداً

# ── Django ─────────────────────────────────────────────────
# أنشئ مفتاحاً عشوائياً: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-min-50-chars-here

# false في الإنتاج دائماً
DEBUG=False

# النطاقات المسموح بها (استخدم * للسماح بكل شيء في الإنتاج)
ALLOWED_HOSTS=*

# مطلوب في الإنتاج - يجب ضبطه كمتغير بيئة في منصة الاستضافة
DJANGO_SETTINGS_MODULE=pdc_backend.settings.production

# ── قاعدة البيانات (Neon PostgreSQL) ───────────────────────
# الأولوية لـ NEON_DATABASE_URL — استخدمه مع Neon serverless
# الصيغة: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# بديل: DATABASE_URL (نفس الصيغة — NEON_DATABASE_URL له الأولوية)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (Upstash مُوصى به للـ serverless) ────────────────
# الصيغة: rediss://default:password@host.upstash.io:port
REDIS_URL=rediss://default:your-upstash-password@your-upstash-host.upstash.io:6379

# ── Cloudflare R2 (تخزين الصور) ────────────────────────────
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ── OpenAI ──────────────────────────────────────────────────
# استخدم OPENAI_API_KEY_PDC لتجنب التعارض مع متغيرات المنصة
OPENAI_API_KEY_PDC=sk-proj-your-openai-api-key

# ── Google Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Remove.bg (إزالة الخلفيات) ──────────────────────────────
REMOVEBG_API_KEY=your-removebg-api-key

# ── Kie.ai (توليد صور ذكاء اصطناعي) ─────────────────────────
KIE_AI_API_KEY=your-kie-ai-api-key

# ── SAP Integration ─────────────────────────────────────────
SAP_ACTIVE_ENV=DEV
SAP_USERNAME=your-sap-username
SAP_PASSWORD=your-sap-password
SAP_VERIFY_SSL=False
# Proxy إذا كان SAP خلف جدار حماية
SAP_PROXY_URL=https://your-proxy.example.com/sap-proxy
SAP_PROXY_SECRET=your-proxy-secret-key

# ── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS (عند فصل الـ frontend عن الـ backend) ─────────────
# لا حاجة له إذا كانا على نفس النطاق
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
